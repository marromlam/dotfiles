#!/usr/bin/env python3
import json
import subprocess

result = subprocess.run(
    ["gh", "api", "/copilot_internal/user"],
    capture_output=True, text=True
)
d = json.loads(result.stdout)
p = d["quota_snapshots"]["premium_interactions"]

print(f"Plan:             {d['copilot_plan']} ({d['organization_login_list'][0]})")
print(f"Premium requests: {p['remaining']} / {p['entitlement']} remaining ({p['percent_remaining']}%)")
print(f"Resets:           {d['quota_reset_date_utc']}")
