#!/usr/bin/env bash
# Helper script to convert window numbers to fancy Unicode numerals
# Usage: window_to_num <number>

# Fancy number format - Unicode circled numbers
NUMFMT="馃剬鉃娾瀷鉃屸瀺鉃庘瀼鉃愨瀾鉃掆灀"

# Alternative formats (uncomment to use):
# NUMFMT="蟀帯蟀帳蟀帶蟀帾蟀幁蟀幈蟀幊蟀幎蟀幑蟀幖"  # Nerd Font numbers
# NUMFMT="0123456789"              # Plain numbers
# NUMFMT="鉂垛瀷鉃屸瀺鉃庘瀼鉃愨瀾鉃掆灀"            # Alternative style

ID=$1
echo "${NUMFMT:$ID:1}"
